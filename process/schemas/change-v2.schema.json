{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "change-v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "type", "classification", "status", "systems", "quality", "review", "publication", "spec_change", "classification_evidence", "decision", "policy", "compatibility"],
  "properties": {
    "schema_version": {"const": 2},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "title": {"type": "string", "minLength": 1},
    "type": {"enum": ["feature", "bugfix", "maintenance", "emergency"]},
    "classification": {"enum": ["minor", "major", "hotfix"]},
    "status": {"enum": ["draft", "spec_review", "approved", "in_implementation", "ready_to_archive", "archived"]},
    "systems": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "quality": {"type": "object", "additionalProperties": false, "required": ["strategy_ref", "regression_ref"], "properties": {"strategy_ref": {"type": "string", "minLength": 1}, "regression_ref": {"type": "string", "minLength": 1}}},
    "review": {"type": "object", "additionalProperties": false, "required": ["owner_refs"], "properties": {"owner_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}},
    "publication": {"type": "object", "additionalProperties": false, "required": ["required"], "properties": {"required": {"type": "boolean"}, "source_ref": {"type": "string", "minLength": 1}}},
    "spec_change": {"type": "object", "additionalProperties": false, "required": ["required", "delta_paths"], "properties": {"required": {"type": "boolean"}, "delta_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}},
    "classification_evidence": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "value", "source", "rationale"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "value": {"oneOf": [{"type": "boolean"}, {"const": "unknown"}]},
          "source": {"type": "object", "additionalProperties": false, "required": ["kind", "ref"], "properties": {"kind": {"enum": ["proposal", "design", "spec", "human-decision", "external-evidence"]}, "ref": {"type": "string", "minLength": 1}}},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "decision": {"type": "object", "additionalProperties": false, "required": ["owner_type", "owner_id", "state", "evidence_ref"], "properties": {"owner_type": {"const": "human"}, "owner_id": {"type": "string", "minLength": 1}, "state": {"enum": ["pending", "confirmed", "corrected"]}, "evidence_ref": {"type": "string", "minLength": 1}}},
    "policy": {"type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": {"id": {"const": "sdd-core"}, "version": {"const": "1.0.0"}}},
    "compatibility": {"type": "object", "additionalProperties": false, "required": ["source"], "properties": {"source": {"enum": ["native-v2", "legacy-read", "migrated"]}, "legacy_mode": {"enum": ["thin", "full"]}, "legacy_ref": {"type": "string", "minLength": 1}}, "allOf": [{"if": {"properties": {"source": {"const": "native-v2"}}}, "then": {"not": {"required": ["legacy_mode"]}}, "else": {"required": ["legacy_mode", "legacy_ref"]}}]},
    "extensions": {"type": "object", "propertyNames": {"pattern": "^[a-z][a-z0-9-]*$"}}
  }
}
