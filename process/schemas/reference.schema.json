{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reference.schema.json",
  "$defs": {
    "repositoryReference": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sibling:[a-z][a-z0-9-]*$"
        },
        {
          "type": "string",
          "pattern": "^registry:[a-z][a-z0-9-]*$"
        },
        {
          "type": "string",
          "allOf": [
            {"pattern": "^path:[A-Za-z0-9 _.-]+(?:/[A-Za-z0-9 _.-]+)*$"},
            {"not": {"pattern": "(?:^path:|/)\\.\\.?(?:/|$)"}},
            {"not": {"pattern": "(?:^path:|/)[A-Za-z0-9 _.-]*[. ](?:/|$)"}},
            {"not": {"pattern": "(?:^path:|/)(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.[A-Za-z0-9 _.-]+)?(?:/|$)"}}
          ]
        }
      ]
    }
  }
}
