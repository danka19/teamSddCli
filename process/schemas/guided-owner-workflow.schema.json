{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guided-owner-workflow.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_id", "routes"],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1"]},
    "catalog_id": {"const": "guided-owner-workflow"},
    "routes": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "situation", "required_facts", "commands", "evidence", "human_decision", "fallbacks"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "situation": {"type": "string", "minLength": 1},
          "required_facts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "allowed_values": {
            "type": "object",
            "additionalProperties": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          },
          "commands": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^scripts/[a-z_]+\\.py$"}},
          "evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "human_decision": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "owner", "consequence"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "owner": {"enum": ["Analyst", "Tech Lead"]},
              "consequence": {"type": "string", "minLength": 1}
            }
          },
          "fallbacks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["surface", "command"],
              "properties": {
                "surface": {"type": "string", "minLength": 1},
                "command": {"type": "string", "pattern": "^scripts/manual_fallback\\.py --unavailable [a-z-]+$"}
              }
            }
          }
        }
      }
    }
  }
}
