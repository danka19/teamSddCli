{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "policy-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_set", "required_corporate_values", "policies"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "policy_set": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"const": "sdd-core"},
        "version": {"const": "1.0.0"}
      }
    },
    "required_corporate_values": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "type": {"enum": ["string", "integer", "mapping"]}
        }
      }
    },
    "policies": {
      "type": "array", "minItems": 9, "maxItems": 9,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "version", "kind", "path", "schema", "requires"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "version": {"const": "1.0.0"},
          "kind": {"enum": ["classification", "artifact-matrix", "gates", "regression", "flow-controls", "release", "pilot-safety", "failed-runs", "tech-lead"]},
          "path": {"type": "string", "pattern": "^policies/[a-z][a-z0-9-]*\\.yaml$"},
          "schema": {"const": "schemas/policy-document.schema.json"},
          "requires": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    }
  }
}
