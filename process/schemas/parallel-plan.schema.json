{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "parallel-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "integration_owner", "tasks", "combined_checks", "promotion_requested", "promotion_evidence"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "plan_id": {"type": "string", "minLength": 1},
    "integration_owner": {"type": "string", "minLength": 1},
    "tasks": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["task_id", "owner", "dependencies", "write_scopes", "evidence_path", "stop_condition", "focused_checks", "policy_or_lifecycle_decision"], "properties": {"task_id": {"type": "string", "minLength": 1}, "owner": {"type": "string", "minLength": 1}, "dependencies": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "write_scopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "evidence_path": {"type": "string", "minLength": 1}, "stop_condition": {"type": "string", "minLength": 1}, "focused_checks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/check"}}, "policy_or_lifecycle_decision": {"const": false}}}},
    "combined_checks": {"type": "array", "minItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["check_id", "kind", "command"], "properties": {"check_id": {"type": "string", "minLength": 1}, "kind": {"enum": ["integration", "traceability", "review", "conflict"]}, "command": {"type": "string", "minLength": 1}}}},
    "promotion_requested": {"type": "boolean"},
    "promotion_evidence": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["task_results", "combined_results"], "properties": {"task_results": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["task_id", "checks"], "properties": {"task_id": {"type": "string", "minLength": 1}, "checks": {"type": "array", "items": {"$ref": "#/$defs/result"}}}}}, "combined_results": {"type": "array", "items": {"$ref": "#/$defs/result"}}}}]}
  },
  "$defs": {
    "check": {"type": "object", "additionalProperties": false, "required": ["check_id", "command"], "properties": {"check_id": {"type": "string", "minLength": 1}, "command": {"type": "string", "minLength": 1}}},
    "result": {"type": "object", "additionalProperties": false, "required": ["check_id", "result", "evidence"], "properties": {"check_id": {"type": "string", "minLength": 1}, "result": {"enum": ["passed", "failed"]}, "evidence": {"type": "string", "minLength": 1}}}
  }
}
