{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operation-confirmation-event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "card_code", "human_role", "operation_id", "input_digest", "revision_digest", "source_chat_event_ref", "source_event_actor_type", "source_event_sequence", "source_event_timestamp", "card_chat_event_ref", "card_event_actor_type", "card_event_sequence", "card_previous_event_ref", "issued_at", "expires_at", "confirmation_message", "trusted_chat_event_ref", "confirmation_event_actor_type", "confirmation_event_sequence", "confirmed_at", "authority_granted"],
  "properties": {
    "schema_version": {"const": "1.0"}, "record_type": {"const": "operation_confirmation_event"},
    "card_code": {"type": "string", "pattern": "^OPR-[0-9A-F]{12}$"}, "human_role": {"type": "string", "minLength": 1}, "operation_id": {"type": "string", "minLength": 1},
    "input_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "revision_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_chat_event_ref": {"type": "string", "minLength": 1}, "source_event_actor_type": {"const": "human"}, "source_event_sequence": {"type": "integer", "minimum": 0}, "source_event_timestamp": {"type": "string", "format": "date-time"},
    "card_chat_event_ref": {"type": "string", "minLength": 1}, "card_event_actor_type": {"const": "assistant"}, "card_event_sequence": {"type": "integer", "minimum": 0}, "card_previous_event_ref": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"},
    "confirmation_message": {"type": "string", "pattern": "^Подтверждаю OPR-[0-9A-F]{12}$"}, "trusted_chat_event_ref": {"type": "string", "minLength": 1}, "confirmation_event_actor_type": {"const": "human"}, "confirmation_event_sequence": {"type": "integer", "minimum": 0}, "confirmed_at": {"type": "string", "format": "date-time"}, "authority_granted": {"const": false}
  }
}
