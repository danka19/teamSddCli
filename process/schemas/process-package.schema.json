{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "process-package.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package", "openspec", "workflow", "policies", "schemas", "templates", "catalogs", "examples", "read_packs", "role_instructions", "adapters", "certification", "distribution", "canonical_sources"],
  "properties": {
    "schema_version": {"const": "1.1"},
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"const": "sdd-process"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "openspec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli_version"],
      "properties": {"cli_version": {"const": "1.4.1"}}
    },
    "workflow": {"type": "string", "minLength": 1},
    "policies": {"const": "policies/manifest.yaml"},
    "schemas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operations_catalog", "process_package", "workflow", "sdd_config", "projects", "owners", "project_adapter", "reference", "release_allowlist", "release_manifest", "release_certification_selection", "release_host_evidence", "change_v2", "policy_manifest", "policy_document", "gate_evaluation_input", "tech_lead_review_input", "tech_lead_control_record", "corporate_flow_input", "traceability_v2", "external_mapping", "operation_evidence", "upgrade_evidence", "upgrade_check_result", "read_pack_request", "task_launch", "weak_model_operation_plan", "read_pack", "weak_model_operation_evidence", "parallel_plan", "certification_case", "certification_evidence", "coverage_report", "feedback_policy", "role_output_fixture", "actual_certification_operational_result", "corporate_environment_inventory", "corporate_adaptation_checklist", "corporate_pilot_evidence", "corporate_no_fork_assessment"],
      "properties": {
        "operations_catalog": {"const": "schemas/operations-catalog.schema.json"},
        "process_package": {"type": "string", "minLength": 1},
        "workflow": {"type": "string", "minLength": 1},
        "sdd_config": {"type": "string", "minLength": 1},
        "projects": {"type": "string", "minLength": 1},
        "owners": {"type": "string", "minLength": 1},
        "project_adapter": {"type": "string", "minLength": 1},
        "reference": {"type": "string", "minLength": 1},
        "release_allowlist": {"const": "schemas/release-allowlist.schema.json"},
        "release_manifest": {"type": "string", "minLength": 1},
        "release_certification_selection": {"const": "schemas/release-certification-selection.schema.json"},
        "release_host_evidence": {"const": "schemas/release-host-evidence.schema.json"},
        "change_v2": {"const": "schemas/change-v2.schema.json"},
        "policy_manifest": {"const": "schemas/policy-manifest.schema.json"},
        "policy_document": {"const": "schemas/policy-document.schema.json"},
        "gate_evaluation_input": {"const": "schemas/gate-evaluation-input.schema.json"},
        "tech_lead_review_input": {"const": "schemas/tech-lead-review-input.schema.json"},
        "tech_lead_control_record": {"const": "schemas/tech-lead-control-record.schema.json"},
        "corporate_flow_input": {"const": "schemas/corporate-flow-input.schema.json"},
        "traceability_v2": {"const": "schemas/traceability-v2.schema.json"},
        "external_mapping": {"const": "schemas/external-mapping.schema.json"},
        "operation_evidence": {"const": "schemas/operation-evidence.schema.json"},
        "upgrade_evidence": {"const": "schemas/upgrade-evidence.schema.json"},
        "upgrade_check_result": {"const": "schemas/upgrade-check-result.schema.json"},
        "read_pack_request": {"const": "schemas/read-pack-request.schema.json"},
        "task_launch": {"const": "schemas/task-launch.schema.json"},
        "weak_model_operation_plan": {"const": "schemas/weak-model-operation-plan.schema.json"},
        "read_pack": {"const": "schemas/read-pack.schema.json"},
        "weak_model_operation_evidence": {"const": "schemas/weak-model-operation-evidence.schema.json"},
        "parallel_plan": {"const": "schemas/parallel-plan.schema.json"},
        "certification_case": {"const": "schemas/certification-case.schema.json"},
        "certification_evidence": {"const": "schemas/certification-evidence.schema.json"},
        "coverage_report": {"const": "schemas/coverage-report.schema.json"},
        "feedback_policy": {"const": "schemas/feedback-policy.schema.json"},
        "role_output_fixture": {"const": "schemas/role-output-fixture.schema.json"},
        "actual_certification_operational_result": {"const": "schemas/actual-certification-operational-result.schema.json"},
        "guided_owner_workflow": {"const": "schemas/guided-owner-workflow.schema.json"}, "spec_acceptance": {"const": "schemas/spec-acceptance.schema.json"},
        "corporate_environment_inventory": {"const": "schemas/corporate-environment-inventory.schema.json"},
        "corporate_adaptation_checklist": {"const": "schemas/corporate-adaptation-checklist.schema.json"},
        "corporate_pilot_evidence": {"const": "schemas/corporate-pilot-evidence.schema.json"},
        "corporate_no_fork_assessment": {"const": "schemas/corporate-no-fork-assessment.schema.json"}
      }
    },
    "catalogs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operations", "guided_owner_workflow"],
      "properties": {"operations": {"const": "catalogs/operations.yaml"}, "guided_owner_workflow": {"const": "catalogs/guided-owner-workflow.yaml"}}
    },
    "templates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_v2", "change_package", "upgrade_evidence", "corporate_environment_inventory", "corporate_configuration_checklist", "corporate_pilot_entry_checklist", "corporate_pilot_evidence", "corporate_no_fork_assessment"],
      "properties": {
        "change_v2": {"const": "templates/change-v2/change.yaml"},
        "change_package": {"const": "templates/change/change.yaml"},
        "upgrade_evidence": {"const": "templates/upgrade-evidence.yaml"},
        "corporate_environment_inventory": {"const": "templates/corporate-adaptation/environment-inventory.yaml"},
        "corporate_configuration_checklist": {"const": "templates/corporate-adaptation/configuration-checklist.yaml"},
        "corporate_pilot_entry_checklist": {"const": "templates/corporate-adaptation/pilot-entry-checklist.yaml"},
        "corporate_pilot_evidence": {"const": "templates/corporate-adaptation/pilot-evidence.yaml"},
        "corporate_no_fork_assessment": {"const": "templates/corporate-adaptation/no-fork-assessment.yaml"}
      }
    },
    "examples": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "corporate_pilot_evidence", "corporate_no_fork_assessment"],
      "properties": {
        "classification": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "corporate_pilot_evidence": {"const": "examples/corporate-adaptation/pilot-evidence-synthetic.yaml"},
        "corporate_no_fork_assessment": {"const": "examples/corporate-adaptation/no-fork-routed-synthetic.yaml"}
      }
    },
    "read_packs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "guided_owner_workflow"],
      "properties": {
        "classification": {"const": "read-packs/classification.yaml"},
        "guided_owner_workflow": {"const": "read-packs/guided-owner-workflow.yaml"}
      }
    },
    "role_instructions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analyst", "developer", "qa", "tech_lead"],
      "properties": {
        "analyst": {"const": "roles/analyst.md"},
        "developer": {"const": "roles/developer.md"},
        "qa": {"const": "roles/qa.md"},
        "tech_lead": {"const": "roles/tech-lead.md"}
      }
    },
    "gigacode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "files"],
      "properties": {
        "target": {"const": ".gigacode"},
        "files": {"const": ["AGENTS.md", "skills/sdd-process-companion.md"]}
      }
    },    "adapters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qwen_class", "deepseek_class", "gigacode_class"],
      "properties": {
        "qwen_class": {"const": "adapters/qwen-class.yaml"},
        "deepseek_class": {"const": "adapters/deepseek-class.yaml"},
        "gigacode_class": {"const": "adapters/gigacode-class.yaml"}
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_catalog", "coverage_inventory", "ai_disabled_catalog", "qwen_matrix", "runtime_identities"],
      "properties": {
        "case_catalog": {"const": "certification/cases.yaml"},
        "coverage_inventory": {"const": "certification/coverage.yaml"},
        "ai_disabled_catalog": {"const": "certification/ai-disabled-walkthroughs.yaml"},
        "qwen_matrix": {"const": "certification/qwen-matrix.yaml"},
        "runtime_identities": {"const": "certification/runtime-identities.yaml"}
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "roots"],
      "properties": {
        "files": {
          "oneOf": [{"const": ["VERSION", "__init__.py", "actual_certification.py", "certification.py", "corporate_adaptation.py", "errors.py", "feedback_policy.py", "guided_workflow.py", "guided_process_integrity.py", "model_adapter.py", "operation_cli.py", "operation_dispatcher.py", "operations_catalog.py", "operation_plan.py", "package.yaml", "release-allowlist.yaml", "release-certification-selection.yaml", "release_candidate.py", "weak_model_kit.py", "workflow.yaml", "workflow_operations.py"]}, {"const": ["VERSION", "__init__.py", "actual_certification.py", "certification.py", "corporate_adaptation.py", "errors.py", "feedback_policy.py", "guided_workflow.py", "analytics_artifacts.py", "guided_process_integrity.py", "model_adapter.py", "operation_cli.py", "operation_dispatcher.py", "operations_catalog.py", "operation_plan.py", "package.yaml", "release-allowlist.yaml", "release-certification-selection.yaml", "release_candidate.py", "weak_model_kit.py", "workflow.yaml", "workflow_operations.py"]}]
        },
        "roots": {
          "oneOf": [{"const": ["adapters", "catalogs", "certification", "examples", "policies", "read-packs", "roles", "schemas", "templates", "validators"]}, {"const": ["adapters", "catalogs", "certification", "examples", "gigacode", "policies", "read-packs", "roles", "schemas", "templates", "validators"]}]
        }
      }
    },
    "canonical_sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
