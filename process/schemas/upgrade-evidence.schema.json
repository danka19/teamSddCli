{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sdd/upgrade-evidence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_id", "review", "from", "to", "checks", "rollback_or_hold", "evidence_sha256"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "change_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_type", "state", "decision_ref"],
      "properties": {
        "owner_type": {"type": "string"},
        "state": {"type": "string"},
        "decision_ref": {"type": "string", "minLength": 1}
      }
    },
    "from": {"$ref": "#/$defs/identity"},
    "to": {"$ref": "#/$defs/identity"},
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compatibility_evidence_refs", "openspec_strict", "validator_templates"],
      "properties": {
        "compatibility_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "openspec_strict": {"$ref": "#/$defs/passed_check"},
        "validator_templates": {"$ref": "#/$defs/applicable_check"}
      }
    },
    "rollback_or_hold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "instructions"],
      "properties": {
        "strategy": {"enum": ["rollback", "hold"]},
        "instructions": {"type": "string", "minLength": 10}
      }
    },
    "evidence_sha256": {
      "type": "object",
      "minProperties": 3,
      "propertyNames": {"type": "string", "minLength": 1},
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_version", "openspec_version"],
      "properties": {
        "package_version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
        "openspec_version": {"type": "string", "minLength": 1}
      }
    },
    "passed_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence_ref"],
      "properties": {
        "status": {"const": "passed"},
        "evidence_ref": {"type": "string", "minLength": 1}
      }
    },
    "applicable_check": {
      "oneOf": [
        {"$ref": "#/$defs/passed_check"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reason"],
          "properties": {
            "status": {"const": "not_applicable"},
            "reason": {"type": "string", "minLength": 10}
          }
        }
      ]
    }
  }
}
