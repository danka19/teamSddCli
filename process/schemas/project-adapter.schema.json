{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-adapter.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "config_schema_version", "project_id", "team_specs", "process_package", "policy_set", "local_paths"],
  "properties": {
    "schema_version": {"const": "1.1"},
    "config_schema_version": {"const": "1.1"},
    "project_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "team_specs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "config_path"],
      "properties": {
        "reference": {"$ref": "reference.schema.json#/$defs/repositoryReference"},
        "config_path": {"const": "sdd.config.yaml"}
      }
    },
    "process_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"const": "sdd-process"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "policy_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "overrides"],
      "properties": {
        "id": {"const": "sdd-core"},
        "version": {"const": "1.0.0"},
        "overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule_id", "operation", "value"],
            "properties": {
              "rule_id": {"type": "string", "minLength": 1},
              "operation": {"enum": ["set", "add", "remove"]},
              "value": {}
            }
          }
        }
      }
    },
    "local_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "tests"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "tests": {"type": "string", "minLength": 1}
      }
    }
  }
}
