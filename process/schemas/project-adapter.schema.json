{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-adapter.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "config_schema_version", "project_id", "team_specs", "process_package", "local_paths"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "config_schema_version": {"const": "1.0"},
    "project_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "team_specs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "config_path"],
      "properties": {
        "reference": {"$ref": "reference.schema.json#/$defs/repositoryReference"},
        "config_path": {"const": "sdd.config.yaml"}
      }
    },
    "process_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"const": "sdd-process"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "local_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "tests"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "tests": {"type": "string", "minLength": 1}
      }
    }
  }
}
