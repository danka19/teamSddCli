{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "release-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release_id", "process_package", "config_schema_version", "openspec", "included_assets", "compatibility", "evidence", "known_limitations", "rollback_reference"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "release_id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"},
    "process_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"const": "sdd-process"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "config_schema_version": {"const": "1.0"},
    "openspec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli_version"],
      "properties": {"cli_version": {"const": "1.4.1"}}
    },
    "included_assets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "node", "git"],
      "properties": {
        "python": {"type": "string", "minLength": 1},
        "node": {"type": "string", "minLength": 1},
        "git": {"type": "string", "minLength": 1}
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "known_limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "rollback_reference": {"type": "string", "minLength": 1}
  }
}
