{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "traceability-v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "classification", "lifecycle_state", "policy", "links"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "classification": {"enum": ["minor", "major", "hotfix"]},
    "lifecycle_state": {"enum": ["draft", "spec_review", "approved", "in_implementation", "ready_to_archive", "archived"]},
    "policy": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {"id": {"const": "sdd-core"}, "version": {"const": "1.0.0"}}
    },
    "links": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["record_id", "requirement_refs", "scenario_refs", "task_refs", "evidence_links"],
        "properties": {
          "record_id": {"$ref": "#/$defs/id"},
          "requirement_refs": {"$ref": "#/$defs/nonemptyRefs"},
          "scenario_refs": {"$ref": "#/$defs/nonemptyRefs"},
          "task_refs": {"$ref": "#/$defs/nonemptyRefs"},
          "evidence_links": {
            "type": "array", "minItems": 3,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["record_id", "kind", "status", "source_ref", "evidence_refs", "policy_version"],
              "properties": {
                "record_id": {"$ref": "#/$defs/id"},
                "kind": {"enum": ["classification", "dor", "dod", "implementation", "qa", "automation", "architecture", "regression", "control", "release", "approval", "waiver-deferral", "hotfix-reconciliation"]},
                "status": {"enum": ["concrete", "pending", "not-applicable"]},
                "source_ref": {"type": "string", "minLength": 1},
                "evidence_refs": {"$ref": "#/$defs/nonemptyRefs"},
                "policy_version": {"const": "1.0.0"}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "nonemptyRefs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
