{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workflow", "canonical_sources"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "topology", "artifact_dependencies"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "topology": {"const": "central-team-specs"},
        "artifact_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "requires"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
              "requires": {
                "type": "array",
                "uniqueItems": true,
                "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
              }
            }
          }
        }
      }
    },
    "canonical_sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
