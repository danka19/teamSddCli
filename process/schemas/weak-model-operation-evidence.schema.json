{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "weak-model-operation-evidence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "role", "stage", "status", "read_pack_identity", "sources_read", "artifacts_drafted", "checks", "claims", "human_decisions_required", "unresolved_inputs", "residual_limitations", "prohibited_actions_attempted", "human_stop_reached", "human_review_status", "lifecycle_transition_requested", "approval_claimed"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["analyst", "developer", "qa", "tech_lead"]},
    "stage": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft-complete", "blocked", "failed"]},
    "read_pack_identity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "sources_read": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["authority", "stable_id", "path", "sha256"], "properties": {"authority": {"enum": ["canonical", "supporting", "generated-advisory", "evidence"]}, "stable_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}},
    "artifacts_drafted": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "canonical", "canonical_references"], "properties": {"path": {"type": "string", "minLength": 1}, "canonical": {"const": false}, "canonical_references": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["stable_id", "sha256"], "properties": {"stable_id": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}}}}},
    "checks": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["command", "result", "evidence"], "properties": {"command": {"type": "string", "minLength": 1}, "result": {"enum": ["passed", "failed", "not-run"]}, "evidence": {"type": "string", "minLength": 1}}}},
    "claims": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["kind", "value", "evidence"], "properties": {"kind": {"enum": ["validation", "test", "integration", "file-state", "fact"]}, "value": {"type": "object", "additionalProperties": false, "required": ["subject", "summary"], "properties": {"subject": {"type": "string", "minLength": 1}, "summary": {"type": "string", "minLength": 1}}}, "evidence": {"type": "string", "minLength": 1}}}},
    "human_decisions_required": {"type": "array", "items": {"type": "string"}},
    "unresolved_inputs": {"type": "array", "items": {"type": "string"}},
    "residual_limitations": {"type": "array", "items": {"type": "string"}},
    "prohibited_actions_attempted": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "human_stop_reached": {"const": true},
    "human_review_status": {"const": "pending"},
    "lifecycle_transition_requested": {"const": false},
    "approval_claimed": {"const": false}
  }
}
