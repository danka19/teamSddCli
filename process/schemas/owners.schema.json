{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "owners.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "owner_groups", "zones", "default_owner_groups"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "owner_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "roles", "members"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["process_owner", "tech_lead", "analyst", "developer", "qa", "at", "security"]}
          },
          "members": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
          }
        }
      }
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "paths", "owner_groups"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "owner_groups": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
          }
        }
      }
    },
    "default_owner_groups": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
    }
  }
}
