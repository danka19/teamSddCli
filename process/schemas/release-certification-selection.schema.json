{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "release-certification-selection.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_id", "selected"],
  "properties": {
    "schema_version": {"const": "1.1"},
    "selection_id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*-certification-selection$"},
    "selected": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/full_matrix"},
          {"$ref": "#/$defs/baseline_reuse"}
        ]
      },
      "allOf": [
        {"contains": {"type": "object", "properties": {"model_family": {"const": "qwen-class"}}, "required": ["model_family"]}},
        {"contains": {"type": "object", "properties": {"model_family": {"const": "deepseek-class"}}, "required": ["model_family"]}}
      ]
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "path": {"type": "string", "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"},
    "family": {"enum": ["qwen-class", "deepseek-class"]},
    "full_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_family", "mode", "normalized_evidence_path", "raw_logical_root"],
      "properties": {
        "model_family": {"$ref": "#/$defs/family"},
        "mode": {"const": "full-matrix"},
        "normalized_evidence_path": {"$ref": "#/$defs/path"},
        "raw_logical_root": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"}
      }
    },
    "baseline_reuse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_family", "mode", "reuse_reason", "ai_contract_hashes", "baseline", "fresh_preflight"],
      "properties": {
        "model_family": {"$ref": "#/$defs/family"},
        "mode": {"const": "baseline-reuse"},
        "reuse_reason": {"type": "string", "minLength": 20},
        "ai_contract_hashes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {"path": {"$ref": "#/$defs/path"}, "sha256": {"$ref": "#/$defs/sha256"}}
          }
        },
        "baseline": {
          "type": "object",
          "additionalProperties": false,
          "required": ["normalized_evidence_path", "normalized_evidence_sha256", "raw_logical_root", "process_package_version"],
          "properties": {
            "normalized_evidence_path": {"$ref": "#/$defs/path"},
            "normalized_evidence_sha256": {"$ref": "#/$defs/sha256"},
            "raw_logical_root": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"},
            "process_package_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
          }
        },
        "fresh_preflight": {
          "type": "object",
          "additionalProperties": false,
          "required": ["raw_logical_root", "result_path", "result_sha256", "adapter_version"],
          "properties": {
            "raw_logical_root": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"},
            "result_path": {"$ref": "#/$defs/path"},
            "result_sha256": {"$ref": "#/$defs/sha256"},
            "adapter_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}
          }
        }
      }
    }
  }
}
