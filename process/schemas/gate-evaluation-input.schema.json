{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gate-evaluation-input.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "classification", "status", "evaluation_date", "major_impact_hotfix", "evidence", "approvals", "transition_approvals", "external_state"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "classification": {"enum": ["minor", "major", "hotfix"]},
    "status": {"enum": ["draft", "spec_review", "approved", "in_implementation", "ready_to_archive", "archived"]},
    "evaluation_date": {"type": "string", "format": "date"},
    "major_impact_hotfix": {"type": "boolean"},
    "lifecycle_history": {"$ref": "#/$defs/lifecycleHistory"},
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "approvals": {
      "type": "array",
      "items": {"$ref": "#/$defs/approval"}
    },
    "transition_approvals": {
      "type": "array",
      "items": {"$ref": "#/$defs/transitionApproval"}
    },
    "external_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delivered", "deployed", "tracker_done"],
      "properties": {
        "delivered": {"enum": ["unknown", "yes", "no", "not_applicable"]},
        "deployed": {"enum": ["unknown", "yes", "no", "not_applicable"]},
        "tracker_done": {"enum": ["unknown", "yes", "no", "not_applicable"]}
      }
    }
  },
  "$defs": {
    "humanApprover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {"const": "human"},
        "id": {"type": "string", "minLength": 1}
      }
    },
    "lifecycleHistory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "reached_states"],
      "properties": {
        "schema_version": {"const": "1.0"},
        "reached_states": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/reachedState"}
        }
      }
    },
    "reachedState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state", "reached_at", "source_ref", "recorded_by"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "state": {"enum": ["draft", "spec_review", "approved", "in_implementation", "ready_to_archive", "archived"]},
        "reached_at": {"type": "string", "format": "date-time"},
        "source_ref": {"type": "string", "minLength": 1},
        "recorded_by": {"$ref": "#/$defs/humanApprover"}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_type", "owner_id", "state", "evidence_ref"],
      "properties": {
        "owner_type": {"const": "human"},
        "owner_id": {"type": "string", "minLength": 1},
        "state": {"const": "approved"},
        "evidence_ref": {"type": "string", "minLength": 1}
      }
    },
    "transitionApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transition", "owner_type", "owner_id", "state", "evidence_ref"],
      "properties": {
        "transition": {"type": "string", "pattern": "^(draft->spec_review|spec_review->draft|spec_review->approved|approved->in_implementation|in_implementation->ready_to_archive|ready_to_archive->in_implementation|ready_to_archive->archived)$"},
        "owner_type": {"const": "human"},
        "owner_id": {"type": "string", "minLength": 1},
        "state": {"const": "approved"},
        "evidence_ref": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 8}
      },
      "allOf": [{
        "if": {"properties": {"transition": {"enum": ["spec_review->draft", "ready_to_archive->in_implementation"]}}},
        "then": {"required": ["reason"]}
      }]
    },
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "substitute_evidence", "approver", "residual_risk", "follow_up", "expiry"],
      "properties": {
        "reason": {"type": "string", "minLength": 1},
        "substitute_evidence": {"type": "string", "minLength": 1},
        "approver": {"$ref": "#/$defs/humanApprover"},
        "residual_risk": {"type": "string", "minLength": 1},
        "follow_up": {"type": "string", "minLength": 1},
        "expiry": {"$ref": "#/$defs/expiry"}
      }
    },
    "deferral": {
      "type": "object",
      "additionalProperties": false,
      "required": ["substitute_evidence", "owner", "approver", "residual_risk", "follow_up", "expiry", "reconciled"],
      "properties": {
        "substitute_evidence": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "approver": {"$ref": "#/$defs/humanApprover"},
        "residual_risk": {"type": "string", "minLength": 1},
        "follow_up": {"type": "string", "minLength": 1},
        "expiry": {"$ref": "#/$defs/expiry"},
        "reconciled": {"type": "boolean"}
      }
    },
    "expiry": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "date"],
          "properties": {
            "type": {"const": "date"},
            "date": {"type": "string", "format": "date"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "lifecycle_state"],
          "properties": {
            "type": {"const": "lifecycle_state"},
            "lifecycle_state": {"enum": ["draft", "spec_review", "approved", "in_implementation", "ready_to_archive", "archived"]}
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state", "source_ref", "fresh"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "state": {"enum": ["satisfied", "not_applicable", "waived", "deferred", "advisory"]},
        "content": {"type": "string", "minLength": 1},
        "source_ref": {"type": "string", "minLength": 1},
        "source_kind": {"enum": ["artifact", "test", "decision", "external", "ai-statement"]},
        "fresh": {"type": "boolean"},
        "valid_through": {"type": "string", "format": "date"},
        "rationale": {"type": "string", "minLength": 1},
        "approver": {"$ref": "#/$defs/humanApprover"},
        "waiver": {"$ref": "#/$defs/waiver"},
        "deferral": {"$ref": "#/$defs/deferral"},
        "message": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {"if": {"properties": {"state": {"const": "satisfied"}}}, "then": {"required": ["content"]}},
        {"if": {"properties": {"state": {"const": "not_applicable"}}}, "then": {"required": ["rationale", "approver"]}},
        {"if": {"properties": {"state": {"const": "waived"}}}, "then": {"required": ["content", "waiver"]}},
        {"if": {"properties": {"state": {"const": "deferred"}}}, "then": {"required": ["content", "deferral"]}},
        {"if": {"properties": {"state": {"const": "advisory"}}}, "then": {"required": ["message"]}}
      ]
    }
  }
}
