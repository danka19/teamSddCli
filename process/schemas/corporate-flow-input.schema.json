{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "corporate-flow-input.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_id", "evaluation_date", "scope_ids", "evidence_catalog", "records", "tech_lead_control_records"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "change_id": {"$ref": "#/$defs/id"},
    "evaluation_date": {"type": "string", "format": "date"},
    "scope_ids": {"$ref": "#/$defs/idList"},
    "evidence_catalog": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "kind", "ref", "sha256", "scope_ids"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "kind": {"enum": ["document", "decision", "test-result", "artifact", "tracker", "git", "openspec", "pr", "ci", "delivery", "run-output"]},
          "ref": {"$ref": "#/$defs/localRef"},
          "sha256": {"$ref": "#/$defs/digest"},
          "scope_ids": {"$ref": "#/$defs/idList"}
        }
      }
    },
    "records": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/record"}},
    "tech_lead_control_records": {"type": "array", "items": {"$ref": "tech-lead-control-record.schema.json"}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._:-]*$"},
    "idList": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "nonemptyStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "localRef": {"type": "string", "minLength": 1, "not": {"anyOf": [{"pattern": "^[A-Za-z]:"}, {"pattern": "^/"}, {"pattern": "^\\\\"}, {"pattern": "://"}, {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}]}},
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "policySnapshot": {
      "type": "object", "additionalProperties": false, "required": ["id", "version", "digest"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "humanDecision": {
      "type": "object", "additionalProperties": false,
      "required": ["actor_type", "actor_id", "role", "decision_ref"],
      "properties": {
        "actor_type": {"const": "human"}, "actor_id": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1}, "decision_ref": {"$ref": "#/$defs/localRef"}
      }
    },
    "record": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "record_id", "record_type", "scope_ids", "recorded_at", "source_ref", "policy_snapshot", "evidence_refs", "accountable_decision", "payload"],
      "properties": {
        "schema_version": {"const": "1.0"}, "record_id": {"$ref": "#/$defs/id"},
        "record_type": {"enum": ["initiative-triage", "approved-baseline", "scope-drift", "quality-strategy", "regression-row", "qa-decision", "exception", "human-decision", "ai-execution", "release-handoff", "consumer-acceptance", "role-map", "role-walkthrough", "portfolio-wip", "pilot-selection", "failed-run", "pilot-safety"]},
        "scope_ids": {"$ref": "#/$defs/idList"}, "recorded_at": {"type": "string", "format": "date-time"},
        "source_ref": {"$ref": "#/$defs/localRef"}, "policy_snapshot": {"$ref": "#/$defs/policySnapshot"},
        "evidence_refs": {"$ref": "#/$defs/idList"}, "accountable_decision": {"$ref": "#/$defs/humanDecision"},
        "supersedes": {"$ref": "#/$defs/id"}, "payload": {"type": "object"}
      },
      "allOf": [
        {"if": {"properties": {"record_type": {"const": "initiative-triage"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["problem_or_opportunity", "expected_value", "sponsor_or_owner", "affected_contour", "urgency", "dependencies", "constraints", "initial_class_hypothesis", "unanswered_questions", "outcome"], "properties": {"problem_or_opportunity": {"type": "string", "minLength": 1}, "expected_value": {"type": "string", "minLength": 1}, "sponsor_or_owner": {"type": "string", "minLength": 1}, "affected_contour": {"$ref": "#/$defs/nonemptyStrings"}, "urgency": {"type": "string", "minLength": 1}, "dependencies": {"$ref": "#/$defs/strings"}, "constraints": {"$ref": "#/$defs/strings"}, "initial_class_hypothesis": {"enum": ["minor", "major", "hotfix"]}, "unanswered_questions": {"$ref": "#/$defs/strings"}, "outcome": {"enum": ["proceed", "hold", "split", "redirect", "reject"]}}}}}},
        {"if": {"properties": {"record_type": {"const": "approved-baseline"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["requirements", "scenarios", "scope", "exclusions", "dependencies", "classification", "quality_strategy_ref", "decision_version", "approved"], "properties": {"requirements": {"$ref": "#/$defs/nonemptyStrings"}, "scenarios": {"$ref": "#/$defs/nonemptyStrings"}, "scope": {"$ref": "#/$defs/nonemptyStrings"}, "exclusions": {"$ref": "#/$defs/strings"}, "dependencies": {"$ref": "#/$defs/strings"}, "classification": {"enum": ["minor", "major", "hotfix"]}, "quality_strategy_ref": {"$ref": "#/$defs/id"}, "decision_version": {"type": "string", "minLength": 1}, "approved": {"const": true}}}}}},
        {"if": {"properties": {"record_type": {"const": "scope-drift"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["changed_dimensions", "material", "baseline_ref", "reassessments", "approval_decision_ref"], "properties": {"changed_dimensions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["business-behavior", "affected-systems", "risk", "dependencies", "acceptance-criteria", "release-outcome"]}}, "material": {"type": "boolean"}, "baseline_ref": {"$ref": "#/$defs/id"}, "reassessments": {"$ref": "#/$defs/strings"}, "approval_decision_ref": {"$ref": "#/$defs/id"}}}}}},
        {"if": {"properties": {"record_type": {"const": "quality-strategy"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["classification", "scenario_levels", "static_checks", "developer_tests", "qa_manual_evidence", "automation", "data_environment", "regression_scope", "negative_cases", "responsible_roles", "allowed_waivers", "qa_decision_ref"], "properties": {"classification": {"enum": ["minor", "major", "hotfix"]}, "scenario_levels": {"$ref": "#/$defs/nonemptyStrings"}, "static_checks": {"$ref": "#/$defs/nonemptyStrings"}, "developer_tests": {"$ref": "#/$defs/nonemptyStrings"}, "qa_manual_evidence": {"$ref": "#/$defs/strings"}, "automation": {"$ref": "#/$defs/strings"}, "data_environment": {"$ref": "#/$defs/nonemptyStrings"}, "regression_scope": {"$ref": "#/$defs/nonemptyStrings"}, "negative_cases": {"$ref": "#/$defs/nonemptyStrings"}, "responsible_roles": {"$ref": "#/$defs/nonemptyStrings"}, "allowed_waivers": {"$ref": "#/$defs/strings"}, "qa_decision_ref": {"$ref": "#/$defs/id"}}}}}},
        {"if": {"properties": {"record_type": {"const": "regression-row"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["product_or_module", "requirement_scenario", "change_class", "risk_trigger", "required_check", "test_data_environment", "evidence_type", "owner", "current_result", "evidence_ref", "qa_decision_ref"], "properties": {"product_or_module": {"type": "string", "minLength": 1}, "requirement_scenario": {"type": "string", "minLength": 1}, "change_class": {"enum": ["minor", "major", "hotfix"]}, "risk_trigger": {"type": "string", "minLength": 1}, "required_check": {"type": "string", "minLength": 1}, "test_data_environment": {"type": "string", "minLength": 1}, "evidence_type": {"type": "string", "minLength": 1}, "owner": {"type": "string", "minLength": 1}, "current_result": {"enum": ["passed", "failed", "not-run", "stale", "missing", "not-applicable-approved"]}, "evidence_ref": {"$ref": "#/$defs/id"}, "qa_decision_ref": {"$ref": "#/$defs/id"}}}}}},
        {"if": {"properties": {"record_type": {"const": "qa-decision"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["decision_kind", "decision", "material_failures", "missing_evidence", "gate_may_proceed"], "properties": {"decision_kind": {"enum": ["strategy", "regression", "strategy-and-regression"]}, "decision": {"enum": ["sufficient", "passed", "insufficient", "failed", "not-applicable-approved"]}, "material_failures": {"$ref": "#/$defs/strings"}, "missing_evidence": {"$ref": "#/$defs/strings"}, "gate_may_proceed": {"type": "boolean"}}}}}},
        {"if": {"properties": {"record_type": {"const": "exception"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["kind", "affected_obligations", "reason", "substitute_controls", "expires_on", "follow_up", "decision"], "properties": {"kind": {"enum": ["deviation", "waiver", "deferral"]}, "affected_obligations": {"$ref": "#/$defs/nonemptyStrings"}, "reason": {"type": "string", "minLength": 1}, "substitute_controls": {"$ref": "#/$defs/nonemptyStrings"}, "expires_on": {"type": "string", "format": "date"}, "follow_up": {"type": "string", "minLength": 1}, "decision": {"enum": ["approved", "rejected", "expired"]}}}}}},
        {"if": {"properties": {"record_type": {"const": "human-decision"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["decision_type", "source_evidence", "decision", "follow_up"], "properties": {"decision_type": {"type": "string", "minLength": 1}, "source_evidence": {"$ref": "#/$defs/nonemptyStrings"}, "decision": {"type": "string", "minLength": 1}, "follow_up": {"type": "string", "minLength": 1}, "subject_record_ref": {"$ref": "#/$defs/id"}}}}}},
        {"if": {"properties": {"record_type": {"const": "ai-execution"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["model_runtime", "prompt_or_skill_version", "input_scope", "tool_config_version", "output_ref", "reviewer_disposition", "failures", "manual_interventions"], "properties": {"model_runtime": {"type": "string", "minLength": 1}, "prompt_or_skill_version": {"type": "string", "minLength": 1}, "input_scope": {"$ref": "#/$defs/nonemptyStrings"}, "tool_config_version": {"type": "string", "minLength": 1}, "output_ref": {"$ref": "#/$defs/id"}, "reviewer_disposition": {"type": "string", "minLength": 1}, "failures": {"$ref": "#/$defs/strings"}, "manual_interventions": {"$ref": "#/$defs/strings"}}}}}},
        {"if": {"properties": {"record_type": {"const": "release-handoff"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["artifact_version", "included_changes", "requirements_scenarios", "verification_evidence", "known_limitations", "configuration_assumptions", "installation_transfer_steps", "rollback_or_hold", "operations_support_contacts", "unresolved_follow_ups", "chain", "artifact_repository_status"], "properties": {"artifact_version": {"type": "string", "minLength": 1}, "included_changes": {"$ref": "#/$defs/nonemptyStrings"}, "requirements_scenarios": {"$ref": "#/$defs/nonemptyStrings"}, "verification_evidence": {"$ref": "#/$defs/nonemptyStrings"}, "known_limitations": {"$ref": "#/$defs/strings"}, "configuration_assumptions": {"$ref": "#/$defs/strings"}, "installation_transfer_steps": {"$ref": "#/$defs/nonemptyStrings"}, "rollback_or_hold": {"$ref": "#/$defs/nonemptyStrings"}, "operations_support_contacts": {"$ref": "#/$defs/nonemptyStrings"}, "unresolved_follow_ups": {"$ref": "#/$defs/strings"}, "chain": {"type": "object", "additionalProperties": false, "required": ["tracker", "canonical_spec", "implementation", "ci_test", "release", "external_delivery"], "properties": {"tracker": {"$ref": "#/$defs/id"}, "canonical_spec": {"$ref": "#/$defs/id"}, "implementation": {"$ref": "#/$defs/id"}, "ci_test": {"$ref": "#/$defs/id"}, "artifact_repository": {"$ref": "#/$defs/id"}, "release": {"$ref": "#/$defs/id"}, "external_delivery": {"$ref": "#/$defs/id"}}}, "artifact_repository_status": {"enum": ["available", "not-applicable", "unavailable"]}, "artifact_repository_substitute": {"$ref": "#/$defs/id"}, "substitute_decision_ref": {"$ref": "#/$defs/id"}}, "allOf": [{"if": {"properties": {"artifact_repository_status": {"const": "unavailable"}}}, "then": {"required": ["artifact_repository_substitute", "substitute_decision_ref"]}}]}}}},
        {"if": {"properties": {"record_type": {"const": "consumer-acceptance"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["package_ref", "package_version", "receiver", "compatibility_result", "deviations", "decision"], "properties": {"package_ref": {"$ref": "#/$defs/id"}, "package_version": {"type": "string", "minLength": 1}, "receiver": {"type": "string", "minLength": 1}, "compatibility_result": {"enum": ["compatible", "compatible-with-deviation", "incompatible"]}, "deviations": {"$ref": "#/$defs/strings"}, "decision": {"enum": ["accepted", "held", "rejected"]}}}}}},
        {"if": {"properties": {"record_type": {"const": "role-map"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["roles", "architecture_applicable", "security_applicable"], "properties": {"roles": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["role", "owner_type", "owner_id"], "properties": {"role": {"enum": ["product", "analyst", "developer", "qa", "tech_lead", "release_support", "architecture", "security"]}, "owner_type": {"enum": ["human", "group"]}, "owner_id": {"type": "string", "minLength": 1}}}}, "architecture_applicable": {"type": "boolean"}, "security_applicable": {"type": "boolean"}}}}}},
        {"if": {"properties": {"record_type": {"const": "role-walkthrough"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["role", "positive_cases", "negative_cases", "required_inputs", "outputs", "approvals", "forbidden_actions", "stop_escalation", "ai_disabled", "scenario_evidence", "reviewer_disposition"], "properties": {"role": {"type": "string", "minLength": 1}, "positive_cases": {"$ref": "#/$defs/nonemptyStrings"}, "negative_cases": {"$ref": "#/$defs/nonemptyStrings"}, "required_inputs": {"$ref": "#/$defs/nonemptyStrings"}, "outputs": {"$ref": "#/$defs/nonemptyStrings"}, "approvals": {"$ref": "#/$defs/nonemptyStrings"}, "forbidden_actions": {"$ref": "#/$defs/nonemptyStrings"}, "stop_escalation": {"$ref": "#/$defs/nonemptyStrings"}, "ai_disabled": {"const": true}, "scenario_evidence": {"$ref": "#/$defs/nonemptyStrings"}, "reviewer_disposition": {"enum": ["passed", "failed", "incomplete"]}}}}}},
        {"if": {"properties": {"record_type": {"const": "portfolio-wip"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["limit", "limit_source", "active_change_ids", "decision", "decision_owner"], "properties": {"limit": {"type": "integer", "minimum": 1}, "limit_source": {"$ref": "#/$defs/localRef"}, "active_change_ids": {"$ref": "#/$defs/idList"}, "decision": {"enum": ["within-limit", "prioritize", "hold", "authorized-exception"]}, "decision_owner": {"type": "string", "minLength": 1}, "decision_record_ref": {"$ref": "#/$defs/id"}}, "allOf": [{"if": {"properties": {"decision": {"const": "authorized-exception"}}}, "then": {"required": ["decision_record_ref"]}}]}}}},
        {"if": {"properties": {"record_type": {"const": "pilot-selection"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "representativeness", "classification", "systems", "dependencies", "data_security_constraints", "team_readiness", "rollback_feasibility", "exclusion_risks", "selected"], "properties": {"candidate_id": {"$ref": "#/$defs/id"}, "representativeness": {"type": "string", "minLength": 1}, "classification": {"enum": ["minor", "major", "hotfix"]}, "systems": {"$ref": "#/$defs/nonemptyStrings"}, "dependencies": {"$ref": "#/$defs/strings"}, "data_security_constraints": {"$ref": "#/$defs/nonemptyStrings"}, "team_readiness": {"type": "string", "minLength": 1}, "rollback_feasibility": {"enum": ["verified", "unavailable", "unknown"]}, "exclusion_risks": {"$ref": "#/$defs/strings"}, "selected": {"type": "boolean"}}}}}},
        {"if": {"properties": {"record_type": {"const": "failed-run"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["run_id", "attempt_kind", "attempt_ordinal", "outcome", "input_refs", "output_refs", "version_or_configuration", "failure", "owner_disposition", "operational_flags"], "properties": {"run_id": {"$ref": "#/$defs/id"}, "attempt_kind": {"enum": ["validation", "ai", "adapter", "integration", "workflow"]}, "attempt_ordinal": {"type": "integer", "minimum": 1}, "outcome": {"enum": ["failed", "succeeded"]}, "input_refs": {"$ref": "#/$defs/nonemptyStrings"}, "output_refs": {"$ref": "#/$defs/nonemptyStrings"}, "version_or_configuration": {"type": "string", "minLength": 1}, "failure": {"type": "string", "minLength": 1}, "owner_disposition": {"type": "string", "minLength": 1}, "retry_of": {"$ref": "#/$defs/id"}, "predecessor_digest": {"$ref": "#/$defs/digest"}, "operational_flags": {"$ref": "#/$defs/strings"}}}}}},
        {"if": {"properties": {"record_type": {"const": "pilot-safety"}}}, "then": {"properties": {"payload": {"type": "object", "additionalProperties": false, "required": ["risks", "ai_disabled_path"], "properties": {"risks": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["risk", "control", "owner", "evidence_ref", "status"], "properties": {"risk": {"type": "string", "minLength": 1}, "control": {"type": "string", "minLength": 1}, "owner": {"type": "string", "minLength": 1}, "evidence_ref": {"$ref": "#/$defs/id"}, "status": {"enum": ["controlled", "uncontrolled", "unknown"]}}}}, "ai_disabled_path": {"type": "boolean"}}}}}}
      ]
    }
  }
}
