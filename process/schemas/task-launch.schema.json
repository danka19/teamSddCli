{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-launch.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "role", "change_class", "stage_boundary", "instruction_path", "read_pack_path", "read_pack_identity", "verified_source_manifest", "output_contract", "evidence_path", "model_authority", "canonical_mutation_allowed", "human_stop_required", "next_action", "identity"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["analyst", "developer", "qa", "tech_lead"]},
    "change_class": {"enum": ["minor", "major", "hotfix"]},
    "stage_boundary": {"type": "string", "minLength": 1},
    "instruction_path": {"type": "string", "pattern": "^roles/[^/]+\\.md$"},
    "read_pack_path": {"type": "string", "minLength": 1},
    "read_pack_identity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "verified_source_manifest": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["authority", "stable_id", "path", "sha256"], "properties": {"authority": {"enum": ["canonical", "supporting", "generated-advisory", "evidence"]}, "stable_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}},
    "output_contract": {"const": "schemas/weak-model-operation-evidence.schema.json"},
    "evidence_path": {"type": "string", "minLength": 1},
    "model_authority": {"const": "advisory-only"},
    "canonical_mutation_allowed": {"const": false},
    "human_stop_required": {"const": true},
    "next_action": {"type": "string", "minLength": 1},
    "model_response_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "operation", "role_payload_key", "required_artifact_kind", "allowed_reason_codes"],
      "properties": {
        "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$"},
        "operation": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$"},
        "role_payload_key": {"enum": ["requirements_note", "implementation_prep_note", "qa_review_note", "advisory_review_note"]},
        "required_artifact_kind": {"enum": ["evidence-boundary-note", "implementation-prep-note", "qa-review-note", "requirements-note", "tech-lead-review-note"]},
        "allowed_reason_codes": {"const": ["authority-required", "bounded-draft", "conflicting-context", "failed-run-missing", "human-stop-required", "lifecycle-authority-required", "missing-context", "qa-evidence-insufficient", "reconciliation-missing", "unsafe-resume", "unsupported-evidence"]},
        "contract_version": {"const": "2.1"},
        "allowed_artifact_kinds": {"const": ["evidence-boundary-note", "implementation-prep-note", "qa-review-note", "requirements-note", "tech-lead-review-note"]}
      },
      "allOf": [
        {
          "if": {"required": ["contract_version"]},
          "then": {"required": ["allowed_artifact_kinds"]}
        },
        {
          "if": {"required": ["allowed_artifact_kinds"]},
          "then": {"required": ["contract_version"]}
        }
      ]
    },
    "identity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "allOf": [
    {"if": {"properties": {"role": {"const": "analyst"}, "model_response_contract": {"type": "object"}}, "required": ["model_response_contract"]}, "then": {"properties": {"model_response_contract": {"properties": {"role_payload_key": {"const": "requirements_note"}}}}}},
    {"if": {"properties": {"role": {"const": "developer"}, "model_response_contract": {"type": "object"}}, "required": ["model_response_contract"]}, "then": {"properties": {"model_response_contract": {"properties": {"role_payload_key": {"const": "implementation_prep_note"}}}}}},
    {"if": {"properties": {"role": {"const": "qa"}, "model_response_contract": {"type": "object"}}, "required": ["model_response_contract"]}, "then": {"properties": {"model_response_contract": {"properties": {"role_payload_key": {"const": "qa_review_note"}}}}}},
    {"if": {"properties": {"role": {"const": "tech_lead"}, "model_response_contract": {"type": "object"}}, "required": ["model_response_contract"]}, "then": {"properties": {"model_response_contract": {"properties": {"role_payload_key": {"const": "advisory_review_note"}}}}}}
  ]
}
