{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "corporate-no-fork-assessment.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "assessment_id", "recorded_at", "recorded_by_role", "canonical_external_source", "internal_package_fork_detected", "internal_process_package_changes", "findings", "conclusion"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "no-fork-assessment"},
    "assessment_id": {"type": ["string", "null"], "minLength": 1},
    "recorded_at": {"type": ["string", "null"], "format": "date-time"},
    "recorded_by_role": {"type": ["string", "null"], "minLength": 1},
    "canonical_external_source": {"type": ["string", "null"], "minLength": 1},
    "internal_package_fork_detected": {"type": "boolean"},
    "internal_process_package_changes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "conclusion": {"enum": ["template", "compliant", "blocked"]}
  },
  "allOf": [
    {
      "if": {"properties": {"internal_package_fork_detected": {"const": true}}},
      "then": {
        "properties": {
          "internal_process_package_changes": {"minItems": 1},
          "conclusion": {"const": "blocked"}
        }
      }
    },
    {
      "if": {"properties": {"conclusion": {"const": "compliant"}}},
      "then": {"properties": {"internal_package_fork_detected": {"const": false}}}
    },
    {
      "if": {"properties": {"internal_process_package_changes": {"minItems": 1}}},
      "then": {"properties": {"internal_package_fork_detected": {"const": true}, "conclusion": {"const": "blocked"}}}
    },
    {
      "if": {"properties": {"findings": {"contains": {"type": "object", "required": ["internal_package_modified"], "properties": {"internal_package_modified": {"const": true}}}}}},
      "then": {"properties": {"internal_package_fork_detected": {"const": true}, "conclusion": {"const": "blocked"}}}
    }
  ],
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "scope", "description", "disposition", "external_change_ref", "internal_package_modified", "evidence_refs"],
      "properties": {
        "finding_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "scope": {"enum": ["reusable-gap", "local-configuration", "thin-adapter", "environment-only"]},
        "description": {"type": "string", "minLength": 1},
        "disposition": {"enum": ["external-openspec-change", "local-configuration", "thin-adapter", "rejected-internal-fork"]},
        "external_change_ref": {"type": ["string", "null"]},
        "internal_package_modified": {"type": "boolean"},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {
          "if": {"properties": {"scope": {"const": "reusable-gap"}}},
          "then": {
            "properties": {
              "disposition": {"const": "external-openspec-change"},
              "external_change_ref": {"type": "string", "minLength": 1},
              "internal_package_modified": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"scope": {"enum": ["local-configuration", "environment-only"]}}},
          "then": {"properties": {"internal_package_modified": {"const": false}}}
        }
      ]
    }
  }
}
