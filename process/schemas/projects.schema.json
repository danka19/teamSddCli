{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "projects.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "projects"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository", "adapter_allowed", "owner_zones", "local_paths"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "repository": {
            "type": "object",
            "additionalProperties": false,
            "required": ["reference"],
            "properties": {"reference": {"$ref": "reference.schema.json#/$defs/repositoryReference"}}
          },
          "adapter_allowed": {"type": "boolean"},
          "owner_zones": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
          },
          "local_paths": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "tests"],
            "properties": {
              "code": {"type": "string", "minLength": 1},
              "tests": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
