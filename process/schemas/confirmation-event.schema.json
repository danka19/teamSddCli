{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "confirmation-event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "decision_card_code", "change_id", "decision_type", "revision_digest", "source_message", "consequence", "confirmation_message", "source_chat_event_ref", "source_event_actor_type", "source_event_sequence", "source_event_timestamp", "card_chat_event_ref", "card_event_actor_type", "card_event_sequence", "card_previous_event_ref", "issued_at", "trusted_chat_event_ref", "confirmation_event_actor_type", "confirmation_event_sequence", "confirmed_at", "expires_at"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "confirmation_event"},
    "decision_card_code": {"type": "string", "pattern": "^DEC-[0-9A-F]{12}$"},
    "change_id": {"type": "string", "minLength": 1},
    "decision_type": {"type": "string", "minLength": 1},
    "revision_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_message": {"type": "string", "minLength": 1},
    "consequence": {"type": "string", "minLength": 1},
    "confirmation_message": {"type": "string", "pattern": "^(?:Подтверждаю DEC-[0-9A-F]{12}|\\s*Подтверждаю\\s*)$"},
    "source_chat_event_ref": {"type": "string", "minLength": 1},
    "source_event_actor_type": {"const": "human"},
    "source_event_sequence": {"type": "integer", "minimum": 0},
    "source_event_timestamp": {"type": "string", "format": "date-time"},
    "card_chat_event_ref": {"type": "string", "minLength": 1},
    "card_event_actor_type": {"const": "assistant"},
    "card_event_sequence": {"type": "integer", "minimum": 0},
    "card_previous_event_ref": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"},
    "trusted_chat_event_ref": {"type": "string", "minLength": 1},
    "confirmation_event_actor_type": {"const": "human"},
    "confirmation_event_sequence": {"type": "integer", "minimum": 0},
    "confirmed_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"}
  }
}
