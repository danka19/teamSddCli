{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "read-pack.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "role", "change_class", "stage", "status", "sources", "known_traps", "unresolved_inputs", "missing_or_invalid_context", "authority_order", "identity"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["analyst", "developer", "qa", "tech_lead"]},
    "change_class": {"enum": ["minor", "major", "hotfix"]},
    "stage": {"type": "string", "minLength": 1},
    "status": {"enum": ["ready", "blocked"]},
    "sources": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["authority", "stable_id", "path", "sha256", "sections"], "properties": {"authority": {"enum": ["canonical", "supporting", "generated-advisory", "evidence"]}, "stable_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "sections": {"type": "array", "items": {"type": "string"}}}}},
    "known_traps": {"type": "array", "items": {"type": "string"}},
    "unresolved_inputs": {"type": "array", "items": {"type": "string"}},
    "missing_or_invalid_context": {"type": "array", "items": {"type": "object", "required": ["code", "detail"]}},
    "authority_order": {"const": ["canonical", "supporting", "evidence", "generated-advisory"]},
    "identity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
