{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "certification-case.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "planned_dimensions", "cases"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "planned_dimensions": {
      "type": "object", "additionalProperties": false, "required": ["roles", "classes"],
      "properties": {
        "roles": {"type": "array", "minItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["role", "expected_output", "fixture", "sha256", "executed"], "properties": {"role":{"enum":["analyst","developer","qa","tech-lead"]},"expected_output":{"type":"string","minLength":1},"fixture":{"type":"string"},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"executed":{"const":false}}}},
        "classes": {"type": "array", "minItems": 3, "items": {"type": "object", "additionalProperties": false, "required": ["change_class", "executed"], "properties": {"change_class":{"enum":["minor","major","hotfix"]},"executed":{"const":false}}}}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "family", "operation", "fixture", "expected"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "family": {"type": "string"},
          "operation": {"type": "string", "minLength": 1},
          "fixture": {"type": "string"},
          "role": {"enum": ["analyst", "developer", "qa", "tech-lead", "not-applicable"]},
          "change_class": {"enum": ["minor", "major", "hotfix", "not-applicable"]},
          "expected_output": {"type": "string"},
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "codes"],
            "properties": {
              "status": {"enum": ["passed", "blocked"]},
              "codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
            }
          }
        }
      }
    }
  }
}
